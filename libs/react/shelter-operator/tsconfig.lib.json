{
  "extends": "./tsconfig.json",
  "references": [
    {
      "path": "../shelter/tsconfig.lib.json"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "outDir": "../../../dist/out-tsc",
    "types": ["node", "vite/client", "google.maps"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}
