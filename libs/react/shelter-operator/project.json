{
  "name": "react-shelter-operator",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/shelter-operator/src",
  "projectType": "library",
  "tags": [
    "type:feature",
    "scope:shelter-operator"
  ],
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "{workspaceRoot}/apps/betterangels-backend/schema.graphql"
    ]
  },
  "targets": {
    "generate-graphql-types": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/react/shelter-operator/src/lib/**/__generated__/"
      ],
      "options": {
        "cwd": "libs/react/shelter-operator",
        "command": "graphql-codegen --config codegen.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/react/shelter-operator",
        "command": "tsc --noEmit -p tsconfig.lib.json"
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    }
  }
}
