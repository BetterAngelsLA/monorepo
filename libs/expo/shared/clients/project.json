{
  "name": "expo-shared-apollo",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/expo/shared/clients/src",
  "projectType": "library",
  "tags": ["type:util", "scope:shared"],
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "{workspaceRoot}/apps/betterangels-backend/schema.graphql"
    ]
  },
  "targets": {
    "generate-graphql-types": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/expo/shared/clients/src/lib/apollo/graphql/__generated__/"
      ],
      "options": {
        "cwd": "libs/expo/shared/clients",
        "command": "graphql-codegen --config codegen.ts"
      }
    },
    "test": {
      "options": {},
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    }
  }
}
