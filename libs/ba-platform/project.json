{
  "name": "ba-platform",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ba-platform/src",
  "projectType": "library",
  "tags": ["type:data-access", "scope:ba-platform"],
  "namedInputs": {
    "default": ["{projectRoot}/**/*"]
  },
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/ba-platform/jest.config.ts"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/ba-platform",
        "command": "graphql-codegen --config codegen.ts"
      }
    }
  }
}
