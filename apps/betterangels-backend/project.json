{
  "name": "betterangels-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/betterangels-backend/betterangels_backend",
  "tags": ["type:app", "scope:ba-backend"],
  "targets": {
    "lock": {
      "executor": "@nxlv/python:lock",
      "options": {}
    },
    "add": {
      "executor": "@nxlv/python:add",
      "options": {}
    },
    "update": {
      "executor": "@nxlv/python:update",
      "options": {}
    },
    "remove": {
      "executor": "@nxlv/python:remove",
      "options": {}
    },
    "deploy": {
      "command": "tools/deploy/ecs_deploy.sh",
      "configurations": {
        "production": {},
        "preview": {
          "command": "echo 'Skipping deploy'"
        }
      }
    },
    "makemigrations": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py makemigrations",
        "cwd": "apps/betterangels-backend"
      }
    },
    "manage": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py",
        "cwd": "apps/betterangels-backend"
      }
    },
    "check-migrations": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py makemigrations --check",
        "cwd": "apps/betterangels-backend"
      }
    },
    "migrate": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py migrate",
        "cwd": "apps/betterangels-backend"
      }
    },
    "reset_db": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py reset_db",
        "cwd": "apps/betterangels-backend"
      }
    },
    "start": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py runserver 0.0.0.0:8000",
        "cwd": "apps/betterangels-backend"
      }
    },
    "start-scheduler": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run celery -A betterangels_backend beat -S redbeat.RedBeatScheduler",
        "cwd": "apps/betterangels-backend"
      }
    },
    "start-worker": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run celery -A betterangels_backend worker -l INFO",
        "cwd": "apps/betterangels-backend"
      }
    },
    "format": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "commands": ["uv run ruff check --fix .", "uv run ruff format ."],
        "cwd": "apps/betterangels-backend",
        "parallel": false
      }
    },
    "generate-graphql-schema": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run python manage.py export_schema betterangels_backend.schema > schema.graphql",
        "cwd": "apps/betterangels-backend"
      }
    },
    "validate-graphql-schema": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "bash -c 'diff <(uv run python manage.py export_schema betterangels_backend.schema) schema.graphql'",
        "cwd": "apps/betterangels-backend"
      }
    },
    "shell-plus": {
      "command": "cd apps/betterangels-backend && uv run python manage.py shell_plus"
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "args": "--group dev"
      }
    },
    "lint": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "commands": ["uv run ruff check .", "uv run ruff format --check ."],
        "cwd": "apps/betterangels-backend",
        "parallel": false
      }
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "outputs": [
        "{workspaceRoot}/reports/apps/betterangels-backend/unittests",
        "{workspaceRoot}/coverage/apps/betterangels-backend"
      ],
      "options": {
        "command": "uv run pytest",
        "cwd": "apps/betterangels-backend"
      }
    },
    "typecheck": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "commands": ["uv run mypy --config-file=../../mypy.ini ."],
        "cwd": "apps/betterangels-backend",
        "parallel": false
      }
    }
  }
}
