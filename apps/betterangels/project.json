{
  "name": "betterangels",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/betterangels/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "start": {
      "executor": "@nx/expo:start",
      "dependsOn": ["sync-deps"],
      "options": {
        "port": 8081
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx start betterangels"
      }
    },
    "run-ios": {
      "executor": "@nx/expo:run",
      "dependsOn": ["sync-deps"],
      "options": {
        "platform": "ios"
      }
    },
    "run-android": {
      "executor": "@nx/expo:run",
      "dependsOn": ["sync-deps"],
      "options": {
        "platform": "android"
      }
    },
    "eas-build": {
      "executor": "@nx/expo:build",
      "options": {}
    },
    "submit": {
      "executor": "@nx/expo:submit",
      "options": {}
    },
    "build-list": {
      "executor": "@nx/expo:build-list",
      "options": {}
    },
    "download": {
      "executor": "@nx/expo:download",
      "options": {
        "output": "apps/betterangels/dist"
      }
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    },
    "prebuild": {
      "executor": "@nx/expo:prebuild",
      "dependsOn": ["sync-deps"],
      "options": {}
    },
    "install": {
      "executor": "@nx/expo:install",
      "options": {}
    },
    "eas-update": {
      "executor": "@nx/expo:update",
      "options": {
        "auto": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "configurations": {
        "preview": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile preview"
        },
        "production": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile production"
        }
      },
      "defaultConfiguration": "preview"
    },
    "export": {
      "executor": "@nx/expo:export",
      "dependsOn": ["sync-deps"],
      "options": {
        "platform": "all",
        "outputDir": "dist/apps/betterangels"
      },
      "outputs": ["{options.outputDir}"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/betterangels/jest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/betterangels",
        "commands": [
          {
            "command": "tsc --noEmit -p tsconfig.app.json"
          },
          {
            "command": "tsc --noEmit -p tsconfig.spec.json"
          }
        ]
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/betterangels"
      },
      "configurations": {
        "ios": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": { "MAESTRO_PLATFORM": "ios" }
        },
        "android": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": { "MAESTRO_PLATFORM": "android" }
        }
      },
      "defaultConfiguration": "ios"
    },
    "eas-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-e2e-trigger.ts --project betterangels --branch {args.branch} --sha {args.sha}"
      }
    }
  }
}
