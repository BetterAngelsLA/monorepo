{
  "name": "betterangels",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/betterangels/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:betterangels"
  ],
  "targets": {
    "start": {
      "command": "expo start --port 8081",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps"
      ]
    },
    "serve": {
      "command": "expo start --web",
      "options": {
        "cwd": "apps/betterangels"
      }
    },
    "run-ios": {
      "command": "expo run:ios",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps"
      ]
    },
    "run-android": {
      "command": "expo run:android",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps"
      ]
    },
    "build-list": {
      "command": "eas build:list",
      "options": {
        "cwd": "apps/betterangels"
      }
    },
    "eas-build": {
      "command": "eas build",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps",
        "copy-lockfile"
      ]
    },
    "prebuild": {
      "command": "expo prebuild --no-install",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps"
      ]
    },
    "eas-update": {
      "command": "eas update",
      "options": {
        "cwd": "apps/betterangels"
      },
      "dependsOn": [
        "sync-deps",
        "copy-lockfile"
      ]
    },
    "build": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "preview",
      "configurations": {
        "preview": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile preview"
        },
        "production": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile production"
        }
      }
    },
    "export": {
      "outputs": [
        "{projectRoot}/{options.outputDir}",
        "{workspaceRoot}/apps/betterangels/dist"
      ],
      "options": {
        "outputDir": "../../dist/apps/betterangels",
        "platform": "all"
      },
      "dependsOn": [
        "sync-deps"
      ]
    },
    "test": {
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/betterangels",
        "commands": [
          {
            "command": "tsc --noEmit -p tsconfig.app.json"
          },
          {
            "command": "tsc --noEmit -p tsconfig.spec.json"
          }
        ]
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "ios",
      "options": {
        "cwd": "apps/betterangels"
      },
      "configurations": {
        "ios": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": {
            "MAESTRO_PLATFORM": "ios"
          }
        },
        "android": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": {
            "MAESTRO_PLATFORM": "android"
          }
        }
      }
    },
    "eas-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-e2e.ts --project betterangels"
      }
    },
    "copy-lockfile": {
      "command": "node tools/scripts/eas-build-pre-install.mjs . apps/betterangels"
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    }
  }
}
