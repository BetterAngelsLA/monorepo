{
  "name": "betterangels",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/betterangels/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:betterangels"
  ],
  "targets": {
    "start": {
      "executor": "@nx/expo:start",
      "dependsOn": [
        "sync-deps"
      ],
      "options": {
        "port": 8081
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx start betterangels"
      }
    },
    "run-ios": {
      "executor": "@nx/expo:run",
      "dependsOn": [
        "sync-deps"
      ],
      "options": {
        "platform": "ios"
      }
    },
    "run-android": {
      "executor": "@nx/expo:run",
      "dependsOn": [
        "sync-deps"
      ],
      "options": {
        "platform": "android"
      }
    },
    "eas-build": {
      "executor": "@nx/expo:build",
      "options": {}
    },
    "submit": {
      "executor": "@nx/expo:submit",
      "options": {}
    },
    "build-list": {
      "executor": "@nx/expo:build-list",
      "options": {}
    },
    "download": {
      "executor": "@nx/expo:download",
      "options": {
        "output": "apps/betterangels/dist"
      }
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    },
    "prebuild": {
      "executor": "@nx/expo:prebuild",
      "dependsOn": [
        "sync-deps"
      ],
      "options": {}
    },
    "install": {
      "executor": "@nx/expo:install",
      "options": {}
    },
    "eas-update": {
      "executor": "@nx/expo:update",
      "options": {
        "auto": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "preview",
      "configurations": {
        "preview": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile preview"
        },
        "production": {
          "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-deploy.ts --project betterangels --profile production"
        }
      }
    },
    "export": {
      "executor": "@nx/expo:export",
      "dependsOn": [
        "sync-deps"
      ],
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "platform": "all",
        "outputDir": "dist/apps/betterangels"
      }
    },
    "lint": {
      "inputs": [
        "{projectRoot}/**/*"
      ]
    },
    "test": {
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/betterangels",
        "commands": [
          {
            "command": "tsc --noEmit -p tsconfig.app.json"
          },
          {
            "command": "tsc --noEmit -p tsconfig.spec.json"
          }
        ]
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "ios",
      "options": {
        "cwd": "apps/betterangels"
      },
      "configurations": {
        "ios": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": {
            "MAESTRO_PLATFORM": "ios"
          }
        },
        "android": {
          "command": ".maestro/scripts/setup-maestro.sh",
          "env": {
            "MAESTRO_PLATFORM": "android"
          }
        }
      }
    },
    "eas-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --project tools/tsconfig.tools.json tools/scripts/eas-e2e.ts --project betterangels"
      }
    }
  }
}
