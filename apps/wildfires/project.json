{
  "name": "wildfires",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/wildfires/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:wildfires"
  ],
  "targets": {
    "test": {
      "options": {},
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "set-env": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/set-base-path.js"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["set-env"],
      "options": {
        "command": "vite build",
        "cwd": "apps/wildfires"
      },
      "configurations": {
        "preview": {},
        "production": {
          "mode": "production",
          "env": {
            "VITE_ANALYTICS_ENABLED": "true",
            "VITE_ANALYTICS_ID": "G-3FX73WC6WM"
          }
        },
        "development": {
          "mode": "development",
          "env": {
            "VITE_ANALYTICS_ENABLED": "true",
            "VITE_ANALYTICS_ID": "G-VXGSM2MQXZ"
          }
        }
      }
    }
  }
}
