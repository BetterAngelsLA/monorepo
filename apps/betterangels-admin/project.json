{
  "name": "betterangels-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/betterangels-admin/src",
  "projectType": "application",
  "tags": ["type:app", "scope:betterangels-admin"],
  "targets": {
    "test": {
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "apps/betterangels-admin"
      },
      "configurations": {
        "preview": {},
        "production": {}
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/deploy/cloudfront-deploy.mjs"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "post-pr-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/post-preview-comment.js --url=https://admin.dev.betterangels.la"
      }
    }
  }
}
