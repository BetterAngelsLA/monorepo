{
  "name": "betterangels-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/betterangels-admin/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:betterangels-admin"
  ],
  "targets": {
    "test": {
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "set-env": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/set-base-path.js"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "build": {
      "dependsOn": [
        "set-env"
      ],
      "options": {
        "config": "./vite.config.mts",
        "outDir": "../../dist/apps/betterangels-admin"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "./tools/deploy/cloudfront_deploy.sh"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "post-pr-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/post-preview-comment.js --url=https://admin.dev.betterangels.la$VITE_APP_BASE_PATH"
      }
    }
  }
}
