{
  "name": "shelter-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/shelter-web/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:shelter-web"
  ],
  "targets": {
    "test": {
      "options": {},
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "set-env": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/set-base-path.js"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "build": {
      "dependsOn": [
        "set-env"
      ],
      "options": {
        "config": "./vite.config.mts",
        "outDir": "../../dist/apps/shelter-web"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "./tools/deploy/cloudfront_deploy.sh"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "post-pr-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/post-preview-comment.js --url=https://shelter.dev.betterangels.la$VITE_APP_BASE_PATH"
      }
    }
  }
}
