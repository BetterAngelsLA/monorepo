{
  "name": "shelter-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/shelter-web/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:shelter-web"
  ],
  "targets": {
    "test": {
      "options": {},
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "apps/shelter-web"
      },
      "configurations": {
        "preview": {},
        "production": {}
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/deploy/cloudfront-deploy.mjs"
      },
      "configurations": {
        "production": {},
        "preview": {}
      }
    },
    "post-pr-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/post-preview-comment.js --url=https://shelter.dev.betterangels.la"
      }
    }
  }
}
