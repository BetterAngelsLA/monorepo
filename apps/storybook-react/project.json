{
  "name": "storybook-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/storybook-react/src",
  "tags": [],
  "targets": {
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "apps/storybook-react/.storybook",
        "port": 4400
      }
    },
    "build": {
      "executor": "@nx/storybook:build",
      "inputs": [
        "production",
        "^production",
        "{projectRoot}/.storybook/**/*"
      ],
      "outputs": ["{workspaceRoot}/dist/apps/storybook-react"],
      "options": {
        "configDir": "apps/storybook-react/.storybook",
        "outputDir": "dist/apps/storybook-react"
      },
      "configurations": {
        "preview": {},
        "production": {}
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/deploy/cloudfront-deploy.mjs"
      },
      "configurations": {
        "preview": {},
        "production": {
          "command": "echo 'Skipping deploy to PRD'"
        }
      }
    },
    "post-pr-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/post-preview-comment.js --url=https://storybook.dev.betterangels.la"
      }
    }
  }
}
