IMGPROXY_KEY=736563726574
IMGPROXY_SALT=68656C6C6F
IS_LOCAL_DEV=True

# MinIO (local S3-compatible storage for development)
# Override AWS_S3_STORAGE_BUCKET_NAME, LOCAL_S3_INTERNAL_ENDPOINT_URL, and credentials in
# .env.local if you want to use a real AWS bucket instead.
AWS_S3_STORAGE_BUCKET_NAME=betterangels-local
LOCAL_S3_INTERNAL_ENDPOINT_URL=http://minio:9000
LOCAL_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
