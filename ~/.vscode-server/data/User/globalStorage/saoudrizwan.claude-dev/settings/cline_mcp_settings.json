{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "autoApprove": [
        "create_pull_request",
        "create_pull_request_review"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/chrome-devtools-mcp",
        "--chrome-path",
        "/usr/bin/google-chrome"
      ]
    }
  }
}